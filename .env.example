# ===========================================
# HARAS MAJ - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# ===========================================
# DEVELOPMENT MODE (bypasses OAuth)
# ===========================================
DEV_MODE="true"
DEV_USER_ID="dev-user-1"
DEV_USER_NAME="Dev User"
DEV_USER_ROLE="admin"

# ===========================================
# MOCK MODE - Use dados fake em vez de banco
# ===========================================
# set USE_MOCK="true" para usar dados mock (sem necessidade de banco)
USE_MOCK="false"

# ===========================================
# DATABASE (PostgreSQL/Supabase) - Opcional em modo mock
# ===========================================
# Para Supabase, use a string de conexão do dashboard (Settings → Database)
# Formato: postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgres://user:password@localhost:5432/haras_maj"

# ===========================================
# AUTHENTICATION (necessário para produção)
# ===========================================
JWT_SECRET="generate-a-secure-random-string-here"
VITE_APP_ID="your-app-id"
VITE_OAUTH_PORTAL_URL="https://your-oauth-server.com"
OAUTH_SERVER_URL="https://your-oauth-server.com"
OWNER_OPEN_ID="your-owner-openid"

# ===========================================
# OPTIONAL: Built-in Forge API
# ===========================================
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""

# ===========================================
# PORT (optional, default: 3000)
# ===========================================
PORT=3000
