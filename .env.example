# ===========================================
# HARAS MAJ - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# ===========================================
# DEVELOPMENT MODE (bypasses OAuth)
# ===========================================
DEV_MODE="true"
DEV_USER_ID="dev-user-1"
DEV_USER_NAME="Dev User"
DEV_USER_ROLE="admin"

# ===========================================
# DATABASE (MySQL) - Opcional em modo dev
# ===========================================
DATABASE_URL="mysql://user:password@localhost:3306/haras_maj"

# ===========================================
# AUTHENTICATION (necessário para produção)
# ===========================================
JWT_SECRET="generate-a-secure-random-string-here"
VITE_APP_ID="your-app-id"
VITE_OAUTH_PORTAL_URL="https://your-oauth-server.com"
OAUTH_SERVER_URL="https://your-oauth-server.com"
OWNER_OPEN_ID="your-owner-openid"

# ===========================================
# OPTIONAL: Built-in Forge API
# ===========================================
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""

# ===========================================
# PORT (optional, default: 3000)
# ===========================================
PORT=3000
